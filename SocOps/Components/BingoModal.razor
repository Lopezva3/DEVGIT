<div class="fixed inset-0 overlay flex items-center justify-center p-4 z-50">
    <div class="modal-card rounded-xl p-6 max-w-xs w-full text-center animate-[bounce_0.5s_ease-out]">
        <div class="text-5xl mb-4">🎉</div>
        <h2 class="text-3xl font-bold mb-2" style="color:var(--brand-primary)">BINGO!</h2>
        <p class="mb-6">You completed a line!</p>

        <button
            @onclick="OnDismiss"
            class="btn w-full py-3">
            Keep Playing
        </button>
    </div>
</div>

@code {
    [Parameter]
    public EventCallback OnDismiss { get; set; }
}
